{
  "name": "@tenpo/mcp",
  "version": "0.2.12",
  "description": "Tenpo — the operator that runs alongside your store. Connects to 45+ commerce platforms (Shopify, Klaviyo, Meta Ads, GA4, Stripe…) and gives any AI host (Claude Desktop, Cursor, Claude Code, ChatGPT) deterministic answers about your sales, ads, email, inventory, suppliers, customers, finance, and competitors. Free tier, no card required.",
  "license": "MIT",
  "homepage": "https://tenpo.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/tenpo-ai/tenpo-mcp"
  },
  "bugs": {
    "url": "https://github.com/tenpo-ai/tenpo-mcp/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tenpo-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tenpo",
    "shopify",
    "woocommerce",
    "klaviyo",
    "meta-ads",
    "ecommerce",
    "ai-agent",
    "claude-code",
    "cursor"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
